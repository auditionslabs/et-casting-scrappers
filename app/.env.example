GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=bam
DB_USERNAME=dev_root
DB_PASSWORD=

DB_BAM_CONNECTION=mysql
DB_BAM_HOST=
DB_BAM_PORT=3306
DB_BAM_DATABASE=bam
DB_BAM_USERNAME=dev_root
DB_BAM_PASSWORD=

# Required for posting projects/CD users to Explore Talent APIs
EXPLORE_TALENT_API_KEY=

# Optional — only if you enable Meilisearch-related crons or features
# MELISEARCH_BASE_URL=
# MELISEARCH_MASTER_KEY=
# SEARCH_BASE_URL=

# --- TRMX cron dashboard (Settings → Cron jobs) — ./scripts/cron-with-heartbeat.sh ---
# Cron does not load this file. Set these in Coolify (Docker) or in your crontab env block (see crontab.local.example).
# Public origin of the TRMX Nuxt app (no trailing slash). Production: https://trmx.cc — unset = heartbeats skipped, jobs still run.
# TRMX_CRON_HEARTBEAT_BASE_URL=https://trmx.cc
# Same secret as TRMX CRON_HEARTBEAT_SECRET (Bearer to POST /api/cron/jobs/:id/heartbeat)
# CRON_HEARTBEAT_SECRET=
# Optional: ping interval (seconds) for long jobs
# TRMX_CRON_HEARTBEAT_PING_SEC=300
