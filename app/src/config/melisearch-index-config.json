      "_facets.market",
      "_facets.paid",
      "_facets.union",
      "_facets.status",
      "_facets.date_range"
    ],
    "sortableAttributes": [
      "date_created",
      "last_modified",
      "rate",
      "name",
      "location"
    ],
    "rankingRules": [
      "words",
      "typo",
      "proximity",
      "attribute",
      "sort",
      "exactness"
    ],
    "pagination": {
      "maxTotalHits": 1000
    },
    "distinctAttribute": null,
    "typoTolerance": {
      "enabled": true,
      "minWordSizeForTypos": {
        "oneTypo": 4,
        "twoTypos": 8
      },
      "disableOnWords": [],
      "disableOnAttributes": []
    },
    "faceting": {
      "maxValuesPerFacet": 100
    }
  },
