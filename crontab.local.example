# Local WSL/Linux crontab for et-casting-scrappers (no Meilisearch jobs).
#
# Crontab UI (see jobs + per-job logs in the web UI):
#   1. Paste the variable block into "Environment Variables" (fix NVM path if your Node version differs).
#   2. For each job below, click "New", set Name / Job command / schedule, then set log paths if the UI offers them
#      so stdout/stderr match the >> file below (or rely on shell redirection — Crontab UI can still list jobs;
#      tail /tmp/casting-*.log for full output).
#   3. Click "Save to crontab" (or run `crontab-ui --autosave`).
#
# CLI: `crontab -e` and paste the variable block + jobs.
#
# Prereqs:
#   cd app && npm install && npm run build
#   npx playwright install chromium
#   System libraries for Chromium (run once, needs sudo): ./scripts/install-playwright-system-deps.sh
#   app/.env — DB + API keys (Meilisearch vars not required for this template).
#
CRON_TZ=America/Los_Angeles
PATH=/home/bold/.nvm/versions/node/v22.19.0/bin:/usr/bin:/bin
HOME=/home/bold

# TRMX cron dashboard — same values as TRMX server CRON_HEARTBEAT_SECRET; base URL = Nuxt origin (no trailing slash)
TRMX_CRON_HEARTBEAT_BASE_URL=https://trmx.cc
CRON_HEARTBEAT_SECRET=
# Optional: heartbeat ping interval (seconds) for long jobs — leave empty to only send start/stop
# TRMX_CRON_HEARTBEAT_PING_SEC=300

# Project Casting — 10:00 and 18:00 (CRON_TZ). Job IDs must match trmx castingCronCatalog.
0 18 * * * cd /home/bold/dev/et-casting-scrappers/app && ./scripts/cron-with-heartbeat.sh project_casting_18 npm run start:project_casting >> /tmp/casting-project_casting.log 2>&1
0 10 * * * cd /home/bold/dev/et-casting-scrappers/app && ./scripts/cron-with-heartbeat.sh project_casting_10 npm run start:project_casting >> /tmp/casting-project_casting.log 2>&1

# Auditions Free — 18:00
0 18 * * * cd /home/bold/dev/et-casting-scrappers/app && ./scripts/cron-with-heartbeat.sh auditions_free npm run start:auditions_free >> /tmp/casting-auditions_free.log 2>&1

# All Castings — 18:00
0 18 * * * cd /home/bold/dev/et-casting-scrappers/app && ./scripts/cron-with-heartbeat.sh all_castings npm run start:all_castings >> /tmp/casting-all_castings.log 2>&1

# Meilisearch — every 10 minutes
*/10 * * * * cd /home/bold/dev/et-casting-scrappers/app && ./scripts/cron-with-heartbeat.sh melisearch_projects npm run start:add_projects_to_melisearch >> /tmp/casting-melisearch.log 2>&1

# Project markets — every 10 minutes
*/10 * * * * cd /home/bold/dev/et-casting-scrappers/app && ./scripts/cron-with-heartbeat.sh project_markets npm run update:project_markets >> /tmp/casting-project_markets.log 2>&1
